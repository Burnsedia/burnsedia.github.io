---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="w-full max-w-5xl px-6 pt-28 pb-12">
    <h1 class="text-4xl font-black sm:text-5xl">Store</h1>
    <p class="mt-4 max-w-2xl text-base-content/75">
      Product links and downloadable resources are being organized here.
    </p>
  </section>

  <section class="w-full max-w-5xl px-6 pb-20">
    <div class="card border border-base-content/10 bg-base-200/30">
      <div class="card-body">
        <h2 class="card-title">Coming next</h2>
        <p>Expect curated products, templates, and tools connected to the work shared on this site.</p>
        <a href="/support" class="btn btn-primary w-fit">Support the build</a>
      </div>
    </div>
  </section>
</BaseLayout>
