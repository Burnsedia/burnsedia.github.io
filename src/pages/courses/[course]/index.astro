---
import { getCollection } from 'astro:content';
import CourseLessonsList from '../../../components/legacy/CourseLessonsList.astro';
import PageHeader from '../../../components/shared/PageHeader.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../../consts';
import { groupCourseLessons, type CourseGroup } from '../../../utils/courses';

export async function getStaticPaths() {
  const entries = await getCollection('courses');
  const groupedCourses = groupCourseLessons(entries);

  return groupedCourses.map((course) => ({
    params: { course: course.slug },
    props: { course },
  }));
}

const { course } = Astro.props as { course: CourseGroup };

const baseUrl = Astro.site?.toString() ?? 'https://baileyburnsed.dev';
const toAbsoluteUrl = (path: string) => new URL(path, baseUrl).toString();

const courseBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Courses',
      item: toAbsoluteUrl('/courses/'),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: course.title,
      item: toAbsoluteUrl(`/courses/${course.slug}/`),
    },
  ],
};

const lessonsItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${course.title} Lessons`,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: course.lessons.length,
  itemListElement: course.lessons.map((lesson, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: toAbsoluteUrl(`/courses/${course.slug}/${lesson.lessonSlug}/`),
    name: lesson.entry.data.title,
    description: lesson.entry.data.description,
  })),
};
---

<BaseLayout
  title={`${course.title} | Courses | ${SITE_TITLE}`}
  description={course.description}
  canonical={`/courses/${course.slug}/`}
>
  <script type="application/ld+json" set:html={JSON.stringify(courseBreadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(lessonsItemListSchema)} />
  <PageHeader
    eyebrow="Course"
    title={course.title}
    description={course.description}
    typingPrefix="Path"
    typingPhrases={['Lesson by lesson', 'Production-ready patterns', 'Practical implementation']}
  >
    <div class="mt-6 flex flex-wrap gap-3">
      {course.lessons[0] && <a class="btn btn-primary" href={`/courses/${course.slug}/${course.lessons[0].lessonSlug}/`}>Start lesson</a>}
      <a class="btn btn-outline" href="/courses/">All courses</a>
      <span class="badge badge-outline self-center">{course.lessons.length} lessons</span>
    </div>
  </PageHeader>

  <CourseLessonsList course={course} />
</BaseLayout>
