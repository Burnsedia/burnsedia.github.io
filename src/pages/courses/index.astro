---
import { getCollection } from 'astro:content';
import CoursesList from '../../components/legacy/CoursesList.astro';
import PageHeader from '../../components/shared/PageHeader.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { groupCourseLessons } from '../../utils/courses';

const entries = await getCollection('courses');
const courses = groupCourseLessons(entries);

const baseUrl = Astro.site?.toString() ?? 'https://baileyburnsed.dev';
const toAbsoluteUrl = (path: string) => new URL(path, baseUrl).toString();

const coursesBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Courses',
      item: toAbsoluteUrl('/courses/'),
    },
  ],
};

const coursesItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Burnsedia Courses',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: courses.length,
  itemListElement: courses.map((course, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: toAbsoluteUrl(`/courses/${course.slug}/`),
    name: course.title,
    description: `${course.description} (${course.lessons.length} lessons)`,
  })),
};
---
<BaseLayout
  title={`Courses | ${SITE_TITLE}`}
  description="Browse practical software courses with structured lesson paths and production-focused implementation guides."
  canonical="/courses/"
>
  <script type="application/ld+json" set:html={JSON.stringify(coursesBreadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(coursesItemListSchema)} />
  <PageHeader
    eyebrow="Course Directory"
    title="Structured paths, practical outcomes"
    description="Pick a course path and move lesson by lesson. Every lesson links to the next step so you can ship without getting lost."
    typingPrefix="Tracks"
    typingPhrases={['Django', 'DRF', 'SaaS systems', 'Shipping workflows']}
  >
    <div class="mt-6 flex flex-wrap gap-3">
      {courses[0] && <a class="btn btn-primary" href={`/courses/${courses[0].slug}/`}>Start course</a>}
      <a class="btn btn-outline" href="/blog">Read build log</a>
      <a class="btn btn-ghost" href="/projects">Browse projects</a>
    </div>
  </PageHeader>

  <CoursesList courses={courses} />
</BaseLayout>
