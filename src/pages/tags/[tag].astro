---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../../components/legacy/FormattedDate.astro';
import PageHeader from '../../components/shared/PageHeader.astro';
import { SITE_TITLE } from '../../consts';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getNormalizedTags, getTagLabel, hasTag, normalizeTag } from '../../utils/tags';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = new Set<string>();

  posts.forEach((post) => {
    getNormalizedTags(post.data.tags).forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => ({
    params: { tag },
  }));
}

const tagSlug = normalizeTag(Astro.params.tag ?? '');
const posts = (await getCollection('blog'))
  .filter((post) => hasTag(post.data.tags, tagSlug))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredTags = new Map<string, number>();

posts.forEach((post) => {
  getNormalizedTags(post.data.tags)
    .filter((tag) => tag !== tagSlug)
    .forEach((tag) => {
      featuredTags.set(tag, (featuredTags.get(tag) ?? 0) + 1);
    });
});

const relatedTags = Array.from(featuredTags.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8)
  .map(([slug, count]) => ({
    slug,
    label: getTagLabel(slug),
    count,
  }));

const tagLabel = getTagLabel(tagSlug);
---

<BaseLayout
  title={`${tagLabel} Articles | ${SITE_TITLE}`}
  description={`Read ${tagLabel} articles from Burnsedia with practical guides, case studies, and implementation insights.`}
  canonical={`/tags/${tagSlug}/`}
>
  <PageHeader
    eyebrow="Topic"
    title={tagLabel}
    description={`${posts.length} posts in this topic.`}
  >
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn btn-outline btn-sm" href="/tags/">All tags</a>
    </div>
  </PageHeader>

  <section class="mx-auto w-full max-w-5xl px-4 pb-12">

    {relatedTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-2">
        {relatedTags.map((tag) => (
          <a class="badge badge-outline badge-sm hover:badge-primary" href={`/tags/${tag.slug}/`}>
            {tag.label}
            <span class="badge badge-neutral badge-xs">{tag.count}</span>
          </a>
        ))}
      </div>
    )}

    <div>
      {posts.map((post: BlogPost) => {
        const normalizedTags = getNormalizedTags(post.data.tags);

        return (
          <article class="border-t border-primary/40 py-6">
            <FormattedDate date={post.data.pubDate} />
            <a href={`/blog/${post.slug}/`} class="block">
              <h2 class="mt-2 text-2xl font-semibold leading-snug hover:text-primary transition-colors">{post.data.title}</h2>
            </a>
            <p class="mt-2 text-base text-base-content/80">{post.data.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {normalizedTags.map((tag) => (
                <a
                  class={`badge badge-outline badge-sm ${tag === tagSlug ? 'badge-primary' : 'hover:badge-primary'}`}
                  href={`/tags/${tag}/`}
                >
                  {getTagLabel(tag)}
                </a>
              ))}
            </div>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
