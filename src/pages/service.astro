---
import { SITE_TITLE } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from "../components/marketing/Hero.astro";
import Tech from "../components/legacy/Technolgy.astro";
import SalesHero from "../components/shared/SalesHero.astro";
import Projects from "../components/marketing/projects.astro";
import ContactForm from "../components/marketing/ContactForm.astro";
import Bio from "../components/legacy/Bio.astro";
import Testimonials from "../components/legacy/testimonials.astro"
---
<BaseLayout
  title={`Services | ${SITE_TITLE}`}
	description="Custom software, AI automation, and product development services for founders and small businesses."
  canonical="/service/"
>
 <Hero client:load/>
 <SalesHero />
 <Tech />
 <Projects />
 <Testimonials />
 <Bio />
 <ContactForm />
</BaseLayout>
