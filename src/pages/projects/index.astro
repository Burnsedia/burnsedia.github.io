---
import PageHeader from '../../components/shared/PageHeader.astro';
import ProjectsList from '../../components/legacy/ProjectsList.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';

interface Repo {
  name: string;
  description: string | null;
  language: string | null;
  stargazers_count: number;
  updated_at: string;
  html_url: string;
  fork: boolean;
  archived: boolean;
}

let repos: Repo[] = [];

try {
  const response = await fetch('https://api.github.com/users/Burnsedia/repos?type=public&sort=updated&per_page=30');

  if (response.ok) {
    const data = (await response.json()) as Repo[];
    repos = data
      .filter((repo) => !repo.fork && !repo.archived && repo.name !== 'Burnsedia')
      .sort((a, b) => new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  }
} catch (error) {
  console.error('Failed to fetch GitHub repos:', error);
}

const baseUrl = Astro.site?.toString() ?? 'https://baileyburnsed.dev';
const toAbsoluteUrl = (path: string) => new URL(path, baseUrl).toString();

const projectsBreadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Projects',
      item: toAbsoluteUrl('/projects/'),
    },
  ],
};

const projectsItemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Burnsedia Projects',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: repos.length,
  itemListElement: repos.slice(0, 30).map((repo, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: repo.html_url,
    name: repo.name,
    description: repo.description || 'No description available.',
  })),
};
---

<BaseLayout
  title={`Projects | ${SITE_TITLE}`}
  description="Open-source software and product experiments focused on practical tools, AI workflows, and developer systems."
  canonical="/projects/"
>
  <script type="application/ld+json" set:html={JSON.stringify(projectsBreadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(projectsItemListSchema)} />
  <PageHeader
    eyebrow="Burnsedia Projects"
    title="Open-source tools and product experiments"
    description="A live index of what I am shipping, testing, and maintaining in public."
    typingPrefix="Focused on"
    typingPhrases={['Automation', 'Developer tooling', 'AI systems', 'Open standards']}
  >
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn btn-primary" href="https://github.com/Burnsedia" target="_blank" rel="noopener noreferrer">
        View GitHub Profile
      </a>
      <a class="btn btn-outline" href="/service">Work with me</a>
    </div>
  </PageHeader>
  <ProjectsList repos={repos} />
</BaseLayout>
