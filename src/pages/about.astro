---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroTyping from '../components/shared/HeroTyping.astro';
import HeroLogo from '../components/shared/HeroLogo.astro';
import { SITE_TITLE } from '../consts';
---
<BaseLayout
  title={`About | ${SITE_TITLE}`}
  description="I started coding at 9 and now help founders and small businesses ship practical software with clear ownership and no lock-in."
  canonical="/about/"
>
  <section class="hero py-12 noise">
    <div class="hero-content flex-col lg:flex-row w-full max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="w-2/3 sm:w-full md:w-2/3 mask mask-hexagon ring ring-info ring-offset-4 ring-offset-info p-2 mt-5">
        <HeroLogo />
      </div>
      <div class="w-full">
        <h1 class="text-4xl sm:text-6xl font-bold mb-4">I build shit that works.</h1>
        <p class="text-lg sm:text-xl text-base-content/80 max-w-3xl mb-8">
          No hype. No lock-in. No vaporware. I help founders and small businesses ship practical systems that are maintainable and actually useful.
        </p>
        <HeroTyping
          class="text-base sm:text-xl text-base-content/80 mb-6"
          prefix="I focus on"
          phrases={['Product velocity', 'Systems ownership', 'Clear delivery', 'Sustainable growth']}
        />
        <a href="/service" class="btn btn-primary">Work With Me</a>
      </div>
    </div>
  </section>

  <section class="noise w-full py-16 md:py-20">
    <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">How I got here</h2>
      <div class="max-w-3xl text-base-content/80 space-y-4">
        <p>I started coding at 9 years old.</p>
        <p>I learned C/C++, made Command and Conquer mods in Lua, then built Civilization V mods.</p>
        <p>After high school, I took Harvard CS50, started building my own games, and moved into freelancing.</p>
        <p>I am an autistic hacker nerd and former artist. That mix shapes how I build: practical systems, clear tradeoffs, and strong execution.</p>
      </div>
    </div>
  </section>

  <section class="noise w-full py-16 md:py-20">
    <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">How I build</h2>
      <ul class="space-y-3 text-base-content/80 max-w-3xl">
        <li><strong>Local-first by default:</strong> Keep ownership close and use cloud only when needed.</li>
        <li><strong>Practical over overengineered:</strong> Solve today&apos;s problem cleanly and leave room to scale.</li>
        <li><strong>No lock-in:</strong> Use portable stacks and reversible technical decisions.</li>
        <li><strong>No vaporware:</strong> Working increments beat slide decks and promises.</li>
        <li><strong>Direct and respectful:</strong> Blunt about systems, collaborative with people.</li>
      </ul>
    </div>
  </section>

  <section class="noise w-full py-16 md:py-20">
    <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Off the clock</h2>
      <p class="text-lg text-base-content/70 mb-6 max-w-3xl">
        I still keep a builder mindset outside client work.
      </p>
      <ul class="list-disc pl-6 space-y-2 text-base-content/80 max-w-3xl">
        <li>Digital art in Blender</li>
        <li>Building games in Godot</li>
        <li>CTF challenges and security puzzles</li>
        <li>Rust experiments and tools</li>
      </ul>
    </div>
  </section>

  <section class="noise w-full py-16 md:py-20">
    <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Proof and receipts</h2>
      <p class="text-lg text-base-content/70 mb-8 max-w-3xl">
        I build in public and optimize for outcomes, not theater.
      </p>
      <div class="grid gap-6 md:grid-cols-3">
        <article class="p-5 border border-base-content/10 bg-base-100/5">
          <h3 class="font-semibold mb-2">boomerbill</h3>
          <p class="text-base-content/70">Built publicly on GitHub with a real hosted user.</p>
        </article>
        <article class="p-5 border border-base-content/10 bg-base-100/5">
          <h3 class="font-semibold mb-2">Community</h3>
          <p class="text-base-content/70">Co-organizer of PyATL in Atlanta.</p>
        </article>
        <article class="p-5 border border-base-content/10 bg-base-100/5">
          <h3 class="font-semibold mb-2">Client outcomes</h3>
          <p class="text-base-content/70">Reduced cloud cost with a VPS-first architecture migration.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="noise w-full py-16 md:py-20">
    <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Need it built right?</h2>
      <p class="text-lg text-base-content/70 mb-8 max-w-2xl mx-auto">
        My primary offer is Unlimited Dev Service for teams that need senior execution without agency bloat.
      </p>
      <a href="/service" class="btn btn-primary">See the Unlimited Dev Service</a>
      <p class="mt-4">
        <a href="/blog" class="link link-hover text-base-content/70">Not ready? Follow my build log.</a>
      </p>
    </div>
  </section>
</BaseLayout>
