---
import { render, type CollectionEntry } from 'astro:content';
import FormattedDate from '../components/legacy/FormattedDate.astro';
import { SITE_TITLE } from '../consts';
import { getEntrySlug } from '../utils/content';
import BaseLayout from './BaseLayout.astro';

interface LessonNavItem {
  title: string;
  href: string;
}

interface Props {
  post: CollectionEntry<'courses'>;
  courseSlug?: string;
  courseTitle?: string;
  previousLesson?: LessonNavItem;
  nextLesson?: LessonNavItem;
}

const {
  post,
  courseSlug,
  courseTitle,
  previousLesson,
  nextLesson,
} = Astro.props as Props;

const { Content } = await render(post);
const {
  title,
  description,
  seoTitle,
  seoDescription,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  faq = [],
} = post.data;
const pageTitle = seoTitle ?? title;
const pageDescription = seoDescription ?? description;
const slug = getEntrySlug(post.id);
const lessonSlug = slug.split('/').pop() || slug;
const canonicalPath = courseSlug
  ? `/courses/${courseSlug}/${lessonSlug}/`
  : `/courses/${slug}/`;
const backToCourseHref = courseSlug ? `/courses/${courseSlug}/` : '/courses/';

const baseUrl = Astro.site?.toString() ?? 'https://baileyburnsed.dev';
const toAbsoluteUrl = (path: string) => new URL(path, baseUrl).toString();

const breadcrumbItems = [
  {
    '@type': 'ListItem',
    position: 1,
    name: 'Home',
    item: toAbsoluteUrl('/'),
  },
  {
    '@type': 'ListItem',
    position: 2,
    name: 'Courses',
    item: toAbsoluteUrl('/courses/'),
  },
  ...(courseSlug
    ? [
        {
          '@type': 'ListItem',
          position: 3,
          name: courseTitle ?? 'Course',
          item: toAbsoluteUrl(`/courses/${courseSlug}/`),
        },
      ]
    : []),
  {
    '@type': 'ListItem',
    position: courseSlug ? 4 : 3,
    name: title,
    item: toAbsoluteUrl(canonicalPath),
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems,
};

const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : null;
---
<BaseLayout
  title={`${pageTitle} | ${SITE_TITLE}`}
  description={pageDescription}
  image={heroImage}
  type="article"
  canonical={canonicalPath}
  publishedTime={pubDate.toISOString()}
  updatedTime={updatedDate ? updatedDate.toISOString() : undefined}
  tags={tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <article class="w-full max-w-4xl px-4 sm:px-8 md:px-12 lg:px-16">
    <div class="mb-4 flex flex-wrap items-center gap-2 text-sm">
      <a class="btn btn-ghost btn-sm" href="/courses/">All courses</a>
      {courseSlug && <a class="btn btn-ghost btn-sm" href={backToCourseHref}>{courseTitle ?? 'Course overview'}</a>}
    </div>
    {heroImage && <img class="w-full max-w-4xl rounded-md shadow-lg mask mask-hexagon mt-25" src={heroImage} alt={title} />}
    <h1 class="title py-4 text-3xl md:text-4xl lg:text-5xl text-center">{title}</h1>
    <div class="text-center">
      <FormattedDate date={pubDate} />
      {updatedDate && <div class="last-updated-on">Last updated on <FormattedDate date={updatedDate} /></div>}
    </div>
    <hr />
    <div class="blog-markdown prose lg:prose-lg max-w-none text-base-content">
      <Content />
    </div>

    {faq.length > 0 && (
      <section class="mt-8 rounded-2xl border border-primary/20 bg-base-200/20 p-6">
        <h2 class="text-2xl font-bold">Frequently asked questions</h2>
        <div class="mt-4 space-y-4">
          {faq.map((item) => (
            <details class="rounded-xl border border-base-300 bg-base-100/60 p-4">
              <summary class="cursor-pointer font-semibold">{item.question}</summary>
              <p class="mt-2 text-base-content/80">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 rounded-2xl border border-primary/20 bg-base-200/20 p-6">
      <h2 class="text-2xl font-bold">Use this now</h2>
      <p class="mt-2 text-base-content/80">Apply this exact lesson flow in production and keep momentum between lessons.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="https://boomerbill.net" target="_blank" rel="noopener noreferrer" data-track-event="cta_click" data-track-source="course_lesson" data-track-placement="course_lesson_apply_boomerbill" data-track-label="try-boomerbill">Apply in boomerbill</a>
        <a class="btn btn-outline" href="/newsletter" data-track-event="cta_click" data-track-source="course_lesson" data-track-placement="course_lesson_newsletter" data-track-label="join-newsletter">Get weekly build notes</a>
        <a class="btn btn-ghost" href="/service" data-track-event="work_with_me_click" data-track-source="course_lesson" data-track-placement="course_lesson_work_with_me" data-track-label="work-with-me">Need hands-on help?</a>
      </div>
    </section>

    {(previousLesson || nextLesson) && (
      <nav class="mt-10 grid gap-3 border-t border-primary/40 pt-6 sm:grid-cols-2" aria-label="Course lesson navigation">
        {previousLesson ? (
          <a class="btn btn-outline justify-start" href={previousLesson.href}>← {previousLesson.title}</a>
        ) : (
          <div />
        )}
        {nextLesson ? (
          <a class="btn btn-primary justify-end" href={nextLesson.href}>{nextLesson.title} →</a>
        ) : (
          <a class="btn btn-primary justify-end" href={backToCourseHref}>Finish course</a>
        )}
      </nav>
    )}
  </article>
</BaseLayout>
