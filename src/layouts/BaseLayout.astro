---
import BaseHead from '../components/legacy/BaseHead.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/legacy/Footer.astro';
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  robots?: string;
  publishedTime?: string;
  updatedTime?: string;
  tags?: string[];
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image,
  type = 'website',
  canonical,
  robots,
  publishedTime,
  updatedTime,
  tags,
} = Astro.props;
---

<html lang="en" data-theme="darksynthwave">
  <head>
    <meta charset="utf-8" />
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      canonical={canonical}
      robots={robots}
      publishedTime={publishedTime}
      updatedTime={updatedTime}
      tags={tags}
    />
    <style>
      .title {
        font-size: 2em;
        margin: 0.25em 0 0;
      }
      hr {
        border-top: 1px solid var(--color-base-300);
        margin: 1rem 0;
      }
      .last-updated-on {
        font-style: italic;
      }
    </style>
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen flex flex-col font-sans text-white bg-base-100">
    <Header />
    <main class="flex-1 flex flex-col items-center w-full">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        const SELECTOR = [
          'main section h1',
          'main section h2',
          'main section h3',
          'main section h4',
          'main section h5',
          'main section h6',
          'main section p',
          'main section li',
          'main section blockquote',
          'main .blog-markdown p',
          'main .blog-markdown li',
          'main .blog-markdown blockquote',
          'main [data-anim="reveal"]',
          'main [data-anim="typing"]'
        ].join(', ');

        const MAX_TARGETS = 220;
        const MAX_TYPING_TARGETS = 48;

        const shouldSkip = (element) => {
          if (!(element instanceof HTMLElement)) {
            return true;
          }

          if (element.dataset.animIgnore === 'true') {
            return true;
          }

          if (element.closest('header, footer, nav, pre, code, table, thead, tbody, tfoot, textarea, input, select, button')) {
            return true;
          }

          if (element.classList.contains('btn') || element.classList.contains('badge')) {
            return true;
          }

          return false;
        };

        const isShortTextNode = (element) => {
          if (!(element instanceof HTMLElement)) {
            return false;
          }

          if (element.children.length > 0) {
            return false;
          }

          const text = element.textContent?.trim() ?? '';
          return text.length > 0 && text.length <= 90;
        };

        const runTyping = (element, reduceMotion) => {
          if (!(element instanceof HTMLElement) || element.dataset.animDone === 'true') {
            return;
          }

          const fullText = (element.dataset.animText ?? element.textContent ?? '').trim();
          if (!fullText.length) {
            return;
          }

          if (reduceMotion) {
            element.textContent = fullText;
            element.dataset.animDone = 'true';
            element.classList.add('is-done', 'is-visible');
            return;
          }

          const speed = Number(element.dataset.typeSpeed ?? '18');
          element.dataset.animText = fullText;
          element.textContent = '';
          element.classList.add('type-on-visible');

          let index = 0;
          const tick = () => {
            index += 1;
            element.textContent = fullText.slice(0, index);

            if (index < fullText.length) {
              window.setTimeout(tick, speed);
              return;
            }

            element.dataset.animDone = 'true';
            element.classList.add('is-done', 'is-visible');
          };

          tick();
        };

        const initTextReveal = () => {
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const targets = Array.from(document.querySelectorAll(SELECTOR))
            .filter((node) => !shouldSkip(node))
            .slice(0, MAX_TARGETS);

          if (!targets.length) {
            return;
          }

          if (reduceMotion) {
            targets.forEach((element) => {
              element.classList.remove('reveal-on-visible');
              element.classList.add('is-visible');
              element.style.removeProperty('transition-delay');
            });
            return;
          }

          let typedCount = 0;

          const revealOrType = (element, order) => {
            const animMode = element.getAttribute('data-anim');
            const canType = typedCount < MAX_TYPING_TARGETS && (animMode === 'typing' || isShortTextNode(element));

            if (canType) {
              typedCount += 1;
              const delay = Math.min(order * 20, 260);
              window.setTimeout(() => runTyping(element, reduceMotion), delay);
              return;
            }

            element.classList.add('reveal-on-visible');
            element.style.setProperty('transition-delay', `${Math.min(order * 18, 260)}ms`);
            element.classList.add('is-visible');
            element.dataset.animDone = 'true';
          };

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) {
                  return;
                }

                const element = entry.target;
                const order = Number(element.getAttribute('data-reveal-order') ?? '0');
                revealOrType(element, order);
                observer.unobserve(element);
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
          );

          targets.forEach((element, index) => {
            if (element.classList.contains('is-visible')) {
              return;
            }

            element.setAttribute('data-reveal-order', String(index));

            const rect = element.getBoundingClientRect();
            const isInInitialViewport = rect.top < window.innerHeight * 0.9;

            if (isInInitialViewport) {
              revealOrType(element, index);
              return;
            }

            element.classList.add('reveal-on-visible');
            observer.observe(element);
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initTextReveal, { once: true });
        } else {
          initTextReveal();
        }

        document.addEventListener('astro:page-load', initTextReveal);
      })();
    </script>
  </body>
</html>
