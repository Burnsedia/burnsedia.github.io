---
import BaseHead from '../components/legacy/BaseHead.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/legacy/Footer.astro';
import '../styles/global.css';
import {SITE_TITLE, SITE_DESCRIPTION} from "../consts.ts"
---

<html lang="en" data-theme="darksynthwave">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .title {
        font-size: 2em;
        margin: 0.25em 0 0;
      }
      hr {
        border-top: 1px solid #ddd;
        margin: 1rem 0;
      }
      .last-updated-on {
        font-style: italic;
      }
    </style>
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen font-sans text-white bg-base-100">
    <Header />
    <main class="flex flex-col items-center justify-center">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        let supportViewSentForPath = '';

        const track = (name, label) => {
          if (typeof window.gtag !== 'function') return;
          window.gtag('event', name, {
            event_category: 'engagement',
            event_label: label
          });
        };

        document.addEventListener('click', (event) => {
          const target = event.target instanceof Element ? event.target.closest('[data-ga-event]') : null;
          if (!target) return;

          const eventName = target.getAttribute('data-ga-event');
          if (!eventName) return;

          const eventLabel = target.getAttribute('data-ga-label') || target.getAttribute('href') || 'cta';
          track(eventName, eventLabel);
        });

        const emitSupportPageView = () => {
          if (window.location.pathname !== '/support') return;
          if (typeof window.gtag !== 'function') return;

          const pageKey = `${window.location.pathname}${window.location.search}`;
          if (supportViewSentForPath === pageKey) return;
          supportViewSentForPath = pageKey;

          window.gtag('event', 'support_page_view', {
            page_location: window.location.href,
            page_path: window.location.pathname,
            page_title: document.title
          });
        };

        addEventListener('astro:page-load', emitSupportPageView);
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', emitSupportPageView, { once: true });
        } else {
          emitSupportPageView();
        }
      })();
    </script>
  </body>
</html>
