---
import BaseHead from '../components/legacy/BaseHead.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/legacy/Footer.astro';
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  robots?: string;
  publishedTime?: string;
  updatedTime?: string;
  tags?: string[];
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image,
  type = 'website',
  canonical,
  robots,
  publishedTime,
  updatedTime,
  tags,
} = Astro.props;
---

<html lang="en" data-theme="darksynthwave">
  <head>
    <meta charset="utf-8" />
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      canonical={canonical}
      robots={robots}
      publishedTime={publishedTime}
      updatedTime={updatedTime}
      tags={tags}
    />
    <style>
      .title {
        font-size: 2em;
        margin: 0.25em 0 0;
      }
      hr {
        border-top: 1px solid var(--color-base-300);
        margin: 1rem 0;
      }
      .last-updated-on {
        font-style: italic;
      }
    </style>
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen flex flex-col font-sans text-white bg-base-100">
    <Header />
    <main class="flex-1 flex flex-col items-center w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
