---
import BaseHead from '../components/legacy/BaseHead.astro';
import Header from '../components/shared/Header.astro';
import Footer from '../components/legacy/Footer.astro';
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  canonical?: string;
  robots?: string;
  publishedTime?: string;
  updatedTime?: string;
  tags?: string[];
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image,
  type = 'website',
  canonical,
  robots,
  publishedTime,
  updatedTime,
  tags,
} = Astro.props;
---

<html lang="en" data-theme="darksynthwave">
  <head>
    <meta charset="utf-8" />
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      canonical={canonical}
      robots={robots}
      publishedTime={publishedTime}
      updatedTime={updatedTime}
      tags={tags}
    />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="min-h-screen flex flex-col font-sans text-white bg-base-100">
    <Header />
    <main class="flex-1 flex flex-col items-center w-full">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (() => {
        const SELECTOR = [
          'main section h1',
          'main section h2',
          'main section h3',
          'main section h4',
          'main section h5',
          'main section h6',
          'main section p',
          'main section li',
          'main section blockquote',
          'main .blog-markdown p',
          'main .blog-markdown li',
          'main .blog-markdown blockquote',
          'main [data-anim="reveal"]',
          'main [data-anim="typing"]'
        ].join(', ');

        const MAX_TARGETS = 180;

        const shouldSkip = (element) => {
          if (!(element instanceof HTMLElement)) {
            return true;
          }

          if (element.dataset.animIgnore === 'true') {
            return true;
          }

          if (element.closest('header, footer, nav, pre, code, table, thead, tbody, tfoot, textarea, input, select, button')) {
            return true;
          }

          if (element.classList.contains('btn') || element.classList.contains('badge')) {
            return true;
          }

          return false;
        };

        const initTextReveal = () => {
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          const targets = Array.from(document.querySelectorAll(SELECTOR))
            .filter((node) => !shouldSkip(node))
            .slice(0, MAX_TARGETS);

          if (!targets.length) {
            return;
          }

          if (reduceMotion) {
            targets.forEach((element) => {
              element.classList.remove('reveal-on-visible');
              element.classList.add('is-visible');
              element.style.removeProperty('transition-delay');
            });
            return;
          }

          const revealElement = (element, order) => {
            element.classList.add('reveal-on-visible');
            element.style.setProperty('transition-delay', `${Math.min(order * 14, 180)}ms`);
            element.classList.add('is-visible');
            element.dataset.animDone = 'true';
          };

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) {
                  return;
                }

                const element = entry.target;
                const order = Number(element.getAttribute('data-reveal-order') ?? '0');
                revealElement(element, order);
                observer.unobserve(element);
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
          );

          targets.forEach((element, index) => {
            if (element.classList.contains('is-visible')) {
              return;
            }

            element.setAttribute('data-reveal-order', String(index));

            const rect = element.getBoundingClientRect();
            const isInInitialViewport = rect.top < window.innerHeight * 0.9;

            if (isInInitialViewport) {
              revealElement(element, index);
              return;
            }

            element.classList.add('reveal-on-visible');
            observer.observe(element);
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initTextReveal, { once: true });
        } else {
          initTextReveal();
        }

        document.addEventListener('astro:page-load', initTextReveal);
      })();
    </script>
    <script is:inline>
      (() => {
        const EVENT_NAMES = new Set([
          'cta_click',
          'newsletter_submit',
          'github_sponsor_click',
          'patreon_click',
          'social_follow_click',
          'work_with_me_click',
        ]);

        const RECENT_EVENT_WINDOW_MS = 500;
        const recentEvents = new Map();

        const getPageType = () => {
          const path = window.location.pathname;
          if (path === '/') return 'home';
          if (path.startsWith('/blog/')) return path === '/blog/' ? 'blog_index' : 'blog_post';
          if (path.startsWith('/newsletter')) return 'newsletter';
          if (path.startsWith('/thank-you')) return 'thank_you';
          if (path.startsWith('/service')) return 'service';
          return 'other';
        };

        const track = (eventName, payload) => {
          if (!EVENT_NAMES.has(eventName)) {
            return;
          }

          const dedupeKey = `${eventName}:${payload.placement ?? 'na'}:${payload.label ?? 'na'}:${window.location.pathname}`;
          const now = Date.now();
          const previous = recentEvents.get(dedupeKey) ?? 0;
          if (now - previous < RECENT_EVENT_WINDOW_MS) {
            return;
          }

          recentEvents.set(dedupeKey, now);

          if (typeof window.gtag === 'function') {
            window.gtag('event', eventName, payload);
          }
        };

        const handleClick = (event) => {
          const target = event.target instanceof Element ? event.target : null;
          if (!target) {
            return;
          }

          const element = target.closest('[data-track-event]');
          if (!(element instanceof HTMLElement)) {
            return;
          }

          const eventName = element.dataset.trackEvent;
          if (!eventName) {
            return;
          }

          track(eventName, {
            source: element.dataset.trackSource ?? 'unknown',
            placement: element.dataset.trackPlacement ?? 'unknown',
            label: element.dataset.trackLabel ?? element.textContent?.trim() ?? 'unknown',
            social_platform: element.dataset.trackPlatform,
            destination_url: element instanceof HTMLAnchorElement ? element.href : undefined,
            page_path: window.location.pathname,
            page_type: getPageType(),
          });
        };

        const handleNewsletterSubmit = (event) => {
          const form = event.target;
          if (!(form instanceof HTMLFormElement)) {
            return;
          }

          if (form.name !== 'newsletter') {
            return;
          }

          track('newsletter_submit', {
            source: form.dataset.trackSource ?? 'newsletter_page',
            placement: form.dataset.trackPlacement ?? 'newsletter_form',
            label: 'newsletter-form-submit',
            form_id: form.name,
            page_path: window.location.pathname,
            page_type: getPageType(),
          });
        };

        const initTracking = () => {
          document.removeEventListener('click', handleClick, true);
          document.removeEventListener('submit', handleNewsletterSubmit, true);
          document.addEventListener('click', handleClick, true);
          document.addEventListener('submit', handleNewsletterSubmit, true);
        };

        initTracking();
        document.addEventListener('astro:page-load', initTracking);
      })();
    </script>
  </body>
</html>
