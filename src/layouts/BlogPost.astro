---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/legacy/FormattedDate.astro';
import NewsletterCtaCard from '../components/shared/NewsletterCtaCard.astro';
import { SITE_TITLE } from '../consts';
import { getEntrySlug } from '../utils/content';
import { getNormalizedTags, getTagLabel } from '../utils/tags';
import BaseLayout from './BaseLayout.astro';

type RelatedPost = CollectionEntry<'blog'>;

export interface Props {
  slug: string;
  title: string;
  description: string;
  seoTitle?: string;
  seoDescription?: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  faq?: { question: string; answer: string }[];
  relatedPosts?: RelatedPost[];
}

const {
  slug,
  title,
  description,
  seoTitle,
  seoDescription,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  faq = [],
  relatedPosts = [],
} = Astro.props;

const normalizedTags = getNormalizedTags(tags);
const pageTitle = seoTitle ?? title;
const pageDescription = seoDescription ?? description;
const baseUrl = Astro.site?.toString() ?? 'https://baileyburnsed.dev';
const toAbsoluteUrl = (path: string) => new URL(path, baseUrl).toString();

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: toAbsoluteUrl('/'),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: toAbsoluteUrl('/blog/'),
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: title,
      item: toAbsoluteUrl(`/blog/${slug}/`),
    },
  ],
};

const faqSchema =
  faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faq.map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }
    : null;
---

<BaseLayout
  title={`${pageTitle} | ${SITE_TITLE}`}
  description={pageDescription}
  image={heroImage}
  type="article"
  canonical={`/blog/${slug}/`}
  publishedTime={pubDate.toISOString()}
  updatedTime={updatedDate ? updatedDate.toISOString() : undefined}
  tags={tags}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  <article class="w-full max-w-4xl px-4 sm:px-8 md:px-12 lg:px-16">
    {heroImage && <img class="w-full max-w-4xl rounded-md shadow-lg mask mask-hexagon mt-25" src={heroImage} alt={title} />}
    <h1 class="title py-4 text-3xl md:text-4xl lg:text-5xl text-center">{title}</h1>
    <div class="text-center">
      <FormattedDate date={pubDate} />
      {updatedDate && <div class="last-updated-on">Last updated on <FormattedDate date={updatedDate} /></div>}
    </div>
    {normalizedTags.length > 0 && (
      <div class="mt-4 mb-2 flex flex-wrap justify-center gap-2">
        {normalizedTags.map((tag) => (
          <a class="badge badge-outline badge-sm hover:badge-primary" href={`/tags/${tag}/`}>
            {getTagLabel(tag)}
          </a>
        ))}
      </div>
    )}
    <hr />
    <div class="blog-markdown prose lg:prose-lg max-w-none text-base-content">
      <slot />
    </div>

    {faq.length > 0 && (
      <section class="mt-8 rounded-2xl border border-primary/20 bg-base-200/20 p-6">
        <h2 class="text-2xl font-bold">Frequently asked questions</h2>
        <div class="mt-4 space-y-4">
          {faq.map((item) => (
            <details class="rounded-xl border border-base-300 bg-base-100/60 p-4">
              <summary class="cursor-pointer font-semibold">{item.question}</summary>
              <p class="mt-2 text-base-content/80">{item.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <section class="mt-8 rounded-2xl border border-primary/20 bg-base-200/20 p-6">
      <h2 class="text-2xl font-bold">Apply this in boomerbill</h2>
      <p class="mt-2 text-base-content/80">Use this workflow in a real product and avoid rebuilding the same plumbing from scratch.</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a class="btn btn-primary" href="https://boomerbill.net" target="_blank" rel="noopener noreferrer" data-track-event="cta_click" data-track-source="blog_post" data-track-placement="blog_post_end_boomerbill" data-track-label="try-boomerbill">Try boomerbill</a>
        <a class="btn btn-outline" href="/newsletter" data-track-event="newsletter_click" data-track-source="blog_post" data-track-placement="blog_post_end_newsletter" data-track-label="join-newsletter">Get weekly build notes</a>
        <a class="btn btn-ghost" href="/service" data-track-event="work_with_me_click" data-track-source="blog_post" data-track-placement="blog_post_end_work_with_me" data-track-label="work-with-me">Need implementation help?</a>
      </div>
    </section>

    <section class="mt-8">
      <NewsletterCtaCard placement="blog_post_end_newsletter" source="blog_post" />
    </section>

    {relatedPosts.length > 0 && (
      <section class="mt-10 border-t border-base-300 pt-6">
        <h2 class="text-2xl font-bold mb-4">Related reads</h2>
        <ul class="space-y-3">
          {relatedPosts.map((relatedPost) => (
            <li>
              <a class="link link-hover font-semibold" href={`/blog/${getEntrySlug(relatedPost.id)}/`}>
                {relatedPost.data.title}
              </a>
              <p class="text-sm text-base-content/80">{relatedPost.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
