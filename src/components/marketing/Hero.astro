---
import { SITE_DESCRIPTION } from '../../consts';
import { Typing } from '../typing';
import HeroLogo from '../shared/HeroLogo.astro';
---

<div class="hero py-12 noise">
  <div class="hero-content flex-col lg:flex-row w-full">
    <div class="w-2/3 sm:w-full md:w-2/3 mask mask-hexagon ring ring-info ring-offset-4 ring-offset-info p-2 mt-5">
      <HeroLogo />
    </div>
    <div class="">
      <div class="items-center px-3 ">
         <h1 class="text-2xl sm:text-6xl font-bold px-3">{SITE_DESCRIPTION}</h1>
          <Typing client:load />
      </div>
      <div class="px-3 py-6">
        <h2 class="text-2xl font-bold">Here's how it works:</h2>
        <ol class="list-decimal px-4">
          <li>Pay for 30 days of software development services</li>
          <li>Schedule a zoom meeting to get started</li>
          <li>Assign tasks on a Trello board</li>
          <li>Sit back and relax </li>
        </ol>  
      </div>
      <div class="py-6">
        <a href="https://buy.stripe.com/9B67sM2DH0LhfOq4aeaEE06" class="btn btn-outline btn-primary mx-6">Buy Now</a>
        <a href="sms:+14042134870?body=BOOK%20NOW" class="btn btn-outline btn-accent mx-auto">Book Now</a>
      </div>
    </div>
  </div>
</div>
