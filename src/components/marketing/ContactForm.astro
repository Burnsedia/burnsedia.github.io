<section class="max-w-2xl py-12">
  <div class="text-left">
    <div class="max-w-2xl">
        <p><a class="link link-success" href="https://calendly.com/baileyburnsed/15min">Remember to schedule a 15 minute zoom meeting</a> to have your questions answered. If you’re ready to get started, click here to purchase your first month and start assigning work. References are available on request.</p>
      <div>
        <a href="https://buy.stripe.com/5kAdRT5Rl5Cc3Vm005">
          <button id="myBuyButton" class="btn btn-outline btn-primary mx-6">Buy Now</button>
        </a>
        <a href="https://calendly.com/baileyburnsed/15min">
          <button id="myBookButton" class="btn btn-outline btn-accent">Book Now</button>
        </a>
      </div>
    </div>
  </div>
</section>
<script>
  const buyButton = document.getElementById('myBuyButton');
  const bookButton = document.getElementById('myBookButton');
  const track = (window as Window & { gtag?: (...args: unknown[]) => void }).gtag;

  if (buyButton && typeof track === 'function') {
    buyButton.addEventListener('click', function() {
      track('event', 'purchase', {
        event_category: 'Sales',
        event_label: 'Buy Now Button',
        value: 1,
      });
    });
  }

  if (bookButton && typeof track === 'function') {
    bookButton.addEventListener('click', function() {
      track('event', 'schedule_meeting', {
        event_category: 'Engagement',
        event_label: 'Schedule Meeting Link',
        value: 1,
      });
    });
  }
</script>
