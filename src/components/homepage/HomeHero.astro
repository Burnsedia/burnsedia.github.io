---
import HeroLogo from '../shared/HeroLogo.astro';
---
<div class="hero py-12">
  <div class="hero-content flex-col lg:flex-row w-full">
    <div class="w-2/3 sm:w-full md:w-2/3 mask mask-hexagon ring ring-info ring-offset-4 ring-offset-info p-2 mt-5">
      <HeroLogo />
    </div>
    <div class="">
      <div class="items-center px-3 ">
         <h1 class="text-3xl sm:text-6xl font-bold px-3">I build shit that works.</h1>
         <p class="text-lg sm:text-xl text-base-content/80 px-3 mt-4 max-w-2xl">
           Apps, games, and open tools. No hype. No lock-in. No vaporware.
         </p>
      </div>
      <div class="py-6 px-3 flex flex-wrap gap-3">
        <a href="/service" class="btn btn-primary">Work With Me</a>
        <a href="/blog" class="btn btn-outline btn-accent">Follow My Builds</a>
      </div>
    </div>
  </div>
</div>
