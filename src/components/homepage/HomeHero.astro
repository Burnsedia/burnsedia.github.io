---
import { Image } from 'astro:assets';
import LOGO from "../../assets/CyberPunkLogo2.jpg"
---
<div class="hero py-12">
  <div class="hero-content flex-col lg:flex-row w-full">
    <div class="w-2/3 sm:w-full md:w-2/3 mask mask-hexagon  p-2 mt-5">
      <Image
        src={LOGO}
        alt="praise the Omnissiah"
        width={900}
        height={900}
        quality={70}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div>
      <div class="items-center px-3">
         <h1 class="text-3xl sm:text-6xl font-bold px-3">I build shit that works.</h1>
         <p class="text-lg sm:text-xl text-base-content/80 px-3 mt-4 max-w-2xl">
           Apps, games, and open tools. No hype. No lock-in.
         </p>
      </div>
      <div class="py-6 px-3 flex flex-wrap gap-3">
        <a href="/service" class="btn btn-primary">Work With Me</a>
        <a href="/newsletter" class="btn btn-outline btn-accent">Follow My Builds</a>
      </div>
    </div>
  </div>
</div>
