---
const stats = [
  { label: "Years building software", value: "8+" },
  { label: "Open-source projects", value: "90+" },
  // { label: "Active products", value: "4" },
  { label: "Community role", value: "PyATL co-organizer" },
];
---
<section class="py-20 noise">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">
      Building in public
    </h2>
    <p class="text-lg text-base-content/70 mb-12 max-w-2xl">
      Shipping real software, contributing to open source,
      and supporting developer communities.
    </p>
    <div class="stats stats-vertical sm:stats-horizontal bg-base-100/5 border border-base-content/10 mb-12">
      {stats.map(stat => (
        <div class="stat">
          <div class="stat-title text-base-content/60">
            {stat.label}
          </div>
          <div class="stat-value text-primary">
            {stat.value}
          </div>
        </div>
      ))}
    </div>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 border-t border-base-content/10 pt-8">
      <p class="text-base-content/60 max-w-xl">
        Most of this work is open source and built in public.
        If it helps you, supporting it helps me keep building.
      </p>
      <div class="flex gap-4">
        <a
          href="https://www.patreon.com/Burnsedia"
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="patreon_click"
          data-ga-label="home_stats_patreon"
        >
          <button class="btn btn-primary">Patreon</button>
        </a>
        <a
          href="https://github.com/sponsors/Burnsedia"
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="github_sponsor_click"
          data-ga-label="home_stats_github_sponsors"
        >
          <button class="btn btn-outline">GitHub Sponsors</button>
        </a>
        <a href="/service" data-ga-event="work_with_me_click" data-ga-label="home_stats_work_with_me">
          <button class="btn btn-outline btn-primary">Work With Me</button>
        </a>
      </div>
    </div>
  </div>
</section>
