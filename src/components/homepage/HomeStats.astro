---
const stats = [
  { label: 'Client projects shipped', value: 100, suffix: '%' },
  { label: 'MVP speed (pre-AI)', value: 14, prefix: '~', suffix: ' days' },
  { label: 'MVP speed (with AI)', value: 1, prefix: '~', suffix: ' day' },
  { label: 'Public repos maintained', value: 95, suffix: '+' },
  { label: 'PyATL co-organizer since', value: 2023 },
  { label: 'PyATL meetup cadence', valueText: 'Monthly' },
];
---
<section class="w-full py-16 md:py-20 noise">
  <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">
      Building in public
    </h2>
    <p class="text-lg text-base-content/70 mb-12 max-w-2xl">
      Stats, not slogans. Real delivery and community work.
    </p>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 mb-8">
      {stats.map(stat => (
        <article
          data-stat-card
          class="rounded-box border border-base-content/10 bg-base-100/5 p-4 opacity-0 translate-y-2 transition duration-300 ease-out"
        >
          <p class="text-sm text-base-content/60">
            {stat.label}
          </p>
          {typeof stat.value === 'number' ? (
            <p
              class="text-primary text-xl sm:text-2xl font-bold mt-2 tabular-nums"
              data-stat-value
              data-count-to={String(stat.value)}
              data-prefix={stat.prefix ?? ''}
              data-suffix={stat.suffix ?? ''}
            >
              {`${stat.prefix ?? ''}${stat.value}${stat.suffix ?? ''}`}
            </p>
          ) : (
            <p class="text-primary text-xl sm:text-2xl font-bold mt-2 tabular-nums">{stat.valueText}</p>
          )}
        </article>
      ))}
    </div>
    <p class="text-xs text-base-content/60 mb-12">
      * MVP speed reflects typical time to first shippable version. Final delivery time varies by scope.
    </p>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 border-t border-base-content/10 pt-8">
      <p class="text-base-content/60 max-w-xl">
        Most of this work is open source and built in public. If it helps you,
        support keeps it shipping.
      </p>
      <a href="https://github.com/sponsors/Burnsedia" class="btn btn-outline btn-accent" target="_blank" rel="noopener noreferrer" data-track-event="github_sponsor_click" data-track-source="home" data-track-placement="home_stats_github_sponsor" data-track-label="github-sponsor">Support the Builds</a>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const setupStatsAnimation = () => {
      const cards = Array.from(document.querySelectorAll('[data-stat-card]'));
      if (!cards.length) {
        return;
      }

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const revealCard = (card, delay = 0) => {
        window.setTimeout(() => {
          card.classList.remove('opacity-0', 'translate-y-2');
        }, delay);
      };

      const animateValue = (node) => {
        if (!(node instanceof HTMLElement) || node.dataset.animated === 'true') {
          return;
        }

        const target = Number(node.dataset.countTo ?? '0');
        const prefix = node.dataset.prefix ?? '';
        const suffix = node.dataset.suffix ?? '';

        if (reduceMotion || !Number.isFinite(target)) {
          node.textContent = `${prefix}${target}${suffix}`;
          node.dataset.animated = 'true';
          return;
        }

        const duration = target >= 1000 ? 1400 : 1000;
        const start = performance.now();

        const frame = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(target * eased);
          node.textContent = `${prefix}${current}${suffix}`;

          if (progress < 1) {
            window.requestAnimationFrame(frame);
          } else {
            node.dataset.animated = 'true';
          }
        };

        window.requestAnimationFrame(frame);
      };

      if (reduceMotion) {
        cards.forEach((card) => {
          revealCard(card);
          card.querySelectorAll('[data-stat-value]').forEach((node) => animateValue(node));
        });
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, index) => {
            if (!entry.isIntersecting) {
              return;
            }

            const card = entry.target;
            revealCard(card, index * 70);
            card.querySelectorAll('[data-stat-value]').forEach((node) => animateValue(node));
            observer.unobserve(card);
          });
        },
        { threshold: 0.35 }
      );

      cards.forEach((card) => observer.observe(card));
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupStatsAnimation, { once: true });
    } else {
      setupStatsAnimation();
    }

    document.addEventListener('astro:page-load', setupStatsAnimation);
  })();
</script>
