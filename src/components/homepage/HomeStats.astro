---
const stats = [
  { label: 'Years on GitHub', value: '8+' },
  { label: 'Public repositories', value: '95' },
  { label: 'Past clients (2024-2025)', value: '9' },
];
---
<section class="py-20 noise">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">
      Building in public
    </h2>
    <p class="text-lg text-base-content/70 mb-12 max-w-2xl">
      Real work, real clients, and open builds.
    </p>
    <div class="stats stats-vertical sm:stats-horizontal bg-base-100/5 border border-base-content/10 mb-12">
      {stats.map(stat => (
        <div class="stat">
          <div class="stat-title text-base-content/60">
            {stat.label}
          </div>
          <div class="stat-value text-primary text-lg sm:text-2xl">
            {stat.value}
          </div>
        </div>
      ))}
    </div>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 border-t border-base-content/10 pt-8">
      <p class="text-base-content/60 max-w-xl">
        Most of this work is open source and built in public. If it helps you,
        support keeps it shipping.
      </p>
      <a href="https://github.com/sponsors/Burnsedia" class="btn btn-outline btn-accent">Support the Builds</a>
    </div>
  </div>
</section>
