---
import { getCollection } from 'astro:content';
import { getEntrySlug } from '../../utils/content';

const posts = (await getCollection('blog'))
  .filter(post => post.data.pubDate)
  .sort(
    (a, b) =>
      b.data.pubDate.getTime() - a.data.pubDate.getTime()
  )
  .slice(0, 3);
---
<section class="w-full py-16 md:py-20 noise">
  <div class="mx-auto w-full max-w-5xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">
      From the build log
    </h2>
    <p class="text-lg text-base-content/70 mb-12 max-w-2xl">
      Notes on architecture, tradeoffs, and what actually shipped.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mb-12">
      {posts.map(post => (
        <a
          href={`/blog/${getEntrySlug(post.id)}/`}
          class="p-5 border border-base-content/10 bg-base-100/5 hover:border-primary transition"
        >
          <h3 class="text-lg font-bold mb-2">
            {post.data.title}
          </h3>

          <span class="text-sm text-base-content/60">
            {post.data.pubDate.toLocaleDateString()}
          </span>
        </a>
      ))}
    </div>
    <div class="flex justify-end">
      <a href="/blog" class="btn btn-outline btn-primary">Read Build Log</a>
    </div>
  </div>
</section>
