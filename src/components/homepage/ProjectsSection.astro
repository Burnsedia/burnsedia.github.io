---
const projects = [
  {
    name: 'Unlimited Dev Service',
    description: 'Ongoing development for teams that need shipping, not theater.',
    status: 'Active client delivery',
    detail: 'Built for maintainability, ownership, and clear scope.',
    cta: 'See Service',
    href: '/service',
  },
  {
    name: 'boomerbill',
    description: 'Billing and labor tracking for nerds tired of unpaid tech support.',
    status: 'Live hosted user',
    detail: 'Local-first mindset with practical workflows and no lock-in traps.',
    cta: 'View Build',
    href: 'https://github.com/Burnsedia/boomerbill',
  },
  {
    name: '32bit-Spacer',
    description: 'Retro-futurist space game built in public.',
    status: 'Playable systems in active development',
    detail: 'Lean architecture and iterative releases.',
    cta: 'View Build',
    href: 'https://github.com/Burnsedia/32bit-Spacer',
  },
];
---

<section class="noise py-20">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">What I am building right now</h2>
    <p class="text-lg text-base-content/70 mb-12 max-w-2xl">
      Three active lanes. Real status, no theater.
    </p>

    <div class="grid gap-6 md:grid-cols-3 mb-12">
      {projects.map((project) => (
        <article class="p-5 border border-base-content/10 bg-base-100/5 hover:border-primary transition flex flex-col gap-3">
          <h3 class="text-lg font-bold">{project.name}</h3>
          <p class="text-base-content/80">{project.description}</p>
          <p class="text-sm text-primary">Status: {project.status}</p>
          <p class="text-sm text-base-content/60">{project.detail}</p>
          <a
            href={project.href}
            class="btn btn-outline btn-accent mt-auto"
            target={project.href.startsWith('http') ? '_blank' : undefined}
            rel={project.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {project.cta}
          </a>
        </article>
      ))}
    </div>

    <div class="flex justify-end border-t border-base-content/10 pt-8">
      <a href="/projects" class="btn btn-outline">See All Builds</a>
    </div>
  </div>
</section>
