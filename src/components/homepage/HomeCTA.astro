<section class="py-20 noise">
  <div class="max-w-5xl mx-auto px-6">
    <h2 class="text-3xl sm:text-4xl font-bold mb-4">
      Support the build
    </h2>
    <p class="text-lg text-base-content/70 mb-8 max-w-2xl mx-auto">
      If my open work, writeups, or tools help you,
      support keeps the next release shipping.
    </p>
    <div class="flex flex-col sm:flex-row sm:flex-wrap justify-center gap-4">
      <a
        href="https://www.patreon.com/Burnsedia"
        target="_blank"
        rel="noopener noreferrer"
        data-ga-event="patreon_click"
        data-ga-label="home_cta_patreon"
      >
        <button class="btn btn-primary">Support on Patreon</button>
      </a>
      <a
        href="https://github.com/sponsors/Burnsedia"
        target="_blank"
        rel="noopener noreferrer"
        data-ga-event="github_sponsor_click"
        data-ga-label="home_cta_github_sponsors"
      >
        <button class="btn btn-outline">GitHub Sponsors</button>
      </a>
      <a href="/service" data-ga-event="work_with_me_click" data-ga-label="home_cta_work_with_me">
        <button class="btn btn-ghost">Work With Me</button>
      </a>
      <a href="/newsletter" class="link link-hover text-base-content/80">or join the newsletter</a>
    </div>
  </div>
</section>
