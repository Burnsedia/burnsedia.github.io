---
import { getTagLabel, normalizeTag } from '../../utils/tags';

interface Props {
  title: string;
  description: string;
  tags?: string[];
  tagLinkBase?: string;
}

const { title, description, tags = [], tagLinkBase } = Astro.props as Props;
---
<div class="card bg-base-100 w-full h-full border border-primary shadow-xl min-h-32 hover:shadow-2xl transition-shadow duration-300">
  <div class="card-body">
    <h2 class="card-title text-lg">{title}</h2>
    <p class="text-sm text-base-content">{description}</p>
    {tags && tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag: string) => {
          const slug = normalizeTag(tag);
          const label = getTagLabel(slug);

          return tagLinkBase ? (
            <a class="badge badge-outline badge-sm hover:badge-primary" href={`${tagLinkBase}/${slug}/`}>
              {label}
            </a>
          ) : (
            <span class="badge badge-outline badge-sm" aria-label={`Tag: ${label}`}>
              {label}
            </span>
          );
        })}
      </div>
    )}
  </div>
</div>
