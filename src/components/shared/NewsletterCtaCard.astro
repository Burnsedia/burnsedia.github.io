---
interface Props {
  placement: string;
  source: string;
  title?: string;
  description?: string;
}

const {
  placement,
  source,
  title = 'Get new posts in your inbox',
  description = 'Weekly build notes, practical AI workflows, and lessons from shipping in public.',
} = Astro.props as Props;
---

<section class="rounded-2xl border border-base-content/10 bg-base-100/5 p-6" data-anim="reveal">
  <h3 class="text-xl font-bold">{title}</h3>
  <p class="mt-2 text-base-content/75 max-w-2xl">{description}</p>
  <div class="mt-4 flex flex-wrap gap-3">
    <a
      class="btn btn-primary"
      href="/newsletter"
      data-track-event="cta_click"
      data-track-source={source}
      data-track-placement={placement}
      data-track-label="newsletter-cta"
    >
      Join the Newsletter
    </a>
    <a class="btn btn-ghost" href="/blog">
      Keep Reading
    </a>
  </div>
  <p class="mt-3 text-xs text-base-content/60">Unsubscribe anytime. No spam.</p>
</section>
