---
interface Props {
  course: {
    slug: string;
    lessons: Array<{
      lessonSlug: string;
      entry: {
        data: {
          title: string;
          description: string;
          pubDate: Date;
        };
      };
    }>;
  };
}

const { course } = Astro.props as Props;
const [featuredLesson, ...remainingLessons] = course.lessons;
---

<section class="w-full max-w-5xl px-4 pb-12">
  {featuredLesson && (
    <article class="mb-10 rounded-2xl border border-primary/40 bg-base-200/30 p-6">
      <p class="mb-2 text-xs uppercase tracking-wide text-primary">Start Here</p>
      <a href={`/courses/${course.slug}/${featuredLesson.lessonSlug}/`} class="block">
        <h2 class="text-3xl font-bold leading-tight transition-colors hover:text-primary">{featuredLesson.entry.data.title}</h2>
      </a>
      <p class="mt-3 text-base text-base-content/85">{featuredLesson.entry.data.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-base-content/70">
        <span class="badge badge-primary badge-sm">Lesson 1</span>
        <time datetime={featuredLesson.entry.data.pubDate.toISOString()}>
          {featuredLesson.entry.data.pubDate.toLocaleDateString('en-us', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          })}
        </time>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn btn-primary btn-sm" href={`/courses/${course.slug}/${featuredLesson.lessonSlug}/`}>Start lesson</a>
        <a class="btn btn-outline btn-sm" href={`/courses/${course.slug}/${featuredLesson.lessonSlug}/`}>View details</a>
      </div>
    </article>
  )}

  <div class="space-y-0">
    {remainingLessons.map((lesson, index) => (
      <article class="border-t border-primary/40 py-6">
        <div class="mb-2 flex flex-wrap items-center gap-3 text-sm text-base-content/70">
          <span class="badge badge-outline badge-sm">Lesson {index + 2}</span>
          <time datetime={lesson.entry.data.pubDate.toISOString()}>
            {lesson.entry.data.pubDate.toLocaleDateString('en-us', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
        </div>
        <a href={`/courses/${course.slug}/${lesson.lessonSlug}/`} class="block">
          <h3 class="text-2xl font-semibold leading-snug transition-colors hover:text-primary">{lesson.entry.data.title}</h3>
        </a>
        <p class="mt-2 text-base text-base-content/80">{lesson.entry.data.description}</p>
      </article>
    ))}
  </div>

  <section class="mt-10 rounded-2xl border border-base-300 bg-base-200/30 p-6 text-center">
    <h3 class="text-2xl font-bold">Apply this in production</h3>
    <p class="mt-2 text-base-content/80">Use these patterns in a live stack, keep your lesson momentum, and ship with fewer dead ends.</p>
    <div class="mt-4 flex flex-wrap justify-center gap-3">
      <a
        class="btn btn-primary"
        href="https://boomerbill.net"
        target="_blank"
        rel="noopener noreferrer"
        data-track-event="cta_click"
        data-track-source="course_index"
        data-track-placement="course_index_bottom_boomerbill"
        data-track-label="try-boomerbill"
      >
        Apply this in boomerbill
      </a>
      {remainingLessons[0] && (
        <a class="btn btn-outline" href={`/courses/${course.slug}/${remainingLessons[0].lessonSlug}/`}>Get the next lesson</a>
      )}
      <a
        class="btn btn-ghost"
        href="https://calendly.com/baileyburnsed/15min"
        target="_blank"
        rel="noopener noreferrer"
        data-track-event="work_with_me_click"
        data-track-source="course_index"
        data-track-placement="course_index_bottom_work_with_me"
        data-track-label="book-call-bottom"
      >
        Need hands-on help?
      </a>
    </div>
  </section>
</section>
