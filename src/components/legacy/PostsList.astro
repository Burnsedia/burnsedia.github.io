---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { getNormalizedTags, getTagLabel } from '../../utils/tags';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const [featuredPost, ...remainingPosts] = posts;
---

<section class="w-full max-w-5xl px-4 pb-12">
  {featuredPost && (
    <article class="mb-10 rounded-2xl border border-primary/40 bg-base-200/30 p-6">
      <p class="mb-2 text-xs uppercase tracking-wide text-primary">Featured Post</p>
      <a href={`/blog/${featuredPost.slug}/`} class="block">
        <h2 class="text-3xl font-bold leading-tight hover:text-primary transition-colors">{featuredPost.data.title}</h2>
      </a>
      <p class="mt-3 text-base text-base-content/85">{featuredPost.data.description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-base-content/70">
        <FormattedDate date={featuredPost.data.pubDate} />
      </div>
      {getNormalizedTags(featuredPost.data.tags).length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {getNormalizedTags(featuredPost.data.tags).map((tag) => (
            <a class="badge badge-outline badge-sm hover:badge-primary" href={`/tags/${tag}/`}>
              {getTagLabel(tag)}
            </a>
          ))}
        </div>
      )}
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn btn-primary btn-sm" href="https://calendly.com/baileyburnsed/15min" target="_blank" rel="noopener noreferrer" data-cta="book-call-featured">
          Book a 15-minute call
        </a>
        <a class="btn btn-outline btn-sm" href={`/blog/${featuredPost.slug}/`}>Read article</a>
      </div>
    </article>
  )}

  <div class="space-y-0">
    {remainingPosts.map((post) => {
      const normalizedTags = getNormalizedTags(post.data.tags);

      return (
        <article class="border-t border-primary/40 py-6">
          <div class="mb-2 text-sm text-base-content/70">
            <FormattedDate date={post.data.pubDate} />
          </div>
          <a href={`/blog/${post.slug}/`} class="block">
            <h3 class="text-2xl font-semibold leading-snug hover:text-primary transition-colors">{post.data.title}</h3>
          </a>
          <p class="mt-2 text-base text-base-content/80">{post.data.description}</p>
          {normalizedTags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {normalizedTags.map((tag) => (
                <a class="badge badge-outline badge-sm hover:badge-primary" href={`/tags/${tag}/`}>
                  {getTagLabel(tag)}
                </a>
              ))}
            </div>
          )}
        </article>
      );
    })}
  </div>

  <section class="mt-10 rounded-2xl border border-base-300 bg-base-200/30 p-6 text-center">
    <h3 class="text-2xl font-bold">Need help building this in your product?</h3>
    <p class="mt-2 text-base-content/80">I help founders and teams ship practical AI and software systems without unnecessary complexity.</p>
    <a
      class="btn btn-primary mt-4"
      href="https://calendly.com/baileyburnsed/15min"
      target="_blank"
      rel="noopener noreferrer"
      data-cta="book-call-bottom"
    >
      Book a 15-minute call
    </a>
  </section>
</section>
